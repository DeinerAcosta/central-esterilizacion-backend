generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==========================================
// SEGURIDAD Y USUARIOS
// ==========================================
model Usuario {
  id                    Int      @id @default(autoincrement())
  codigo                String   @unique
  codigoVerificacion    String?
  nombre                String
  apellido              String
  empresa               String
  cargo                 String?
  usuario               String   @unique
  email                 String   @unique
  password              String
  foto                  String?
  rol                   String   @default("Administrador")
  esPropietario         Boolean  @default(false)
  registroContable      Boolean  @default(false)
  permisos              Json?
  esPasswordProvisional Boolean  @default(true)
  estado                Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  hojasDeVidaPropias      HojaVidaInstrumento[]          @relation("PropietarioInstrumento")
  reportesCreados         Reporte[]                      @relation("UsuarioReporta")
  ciclosGestionados       CicloEsterilizacion[]          @relation("ResponsableCiclo")
  // ✅ NUEVO: movimientos de insumos
  movimientosInsumo       MovimientoInsumo[]             @relation("MovimientosInsumo")
  // ✅ NUEVO: módulo Informes - Instrumentos de 3ros
  solicitudesInstrumento  SolicitudRegistroInstrumento[] @relation("SolicitudesUsuario")
  devolucionesResponsable DevolucionTercero[]            @relation("DevolucionesResponsable")
}

// ==========================================
// CONFIGURACIÓN: ESPECIALIDADES Y MARCAS
// ==========================================
model Especialidad {
  id                Int                            @id @default(autoincrement())
  codigo            String                         @unique
  nombre            String                         @unique
  estado            Boolean                        @default(true)
  subespecialidades Subespecialidad[]
  kits              Kit[]
  hojasDeVida       HojaVidaInstrumento[]
  // ✅ NUEVO: solicitudes de instrumento del módulo Informes
  solicitudes       SolicitudRegistroInstrumento[] @relation("SolicitudEspecialidad")
}

model Subespecialidad {
  id             Int                            @id @default(autoincrement())
  codigo         String                         @unique
  nombre         String
  estado         Boolean                        @default(true)
  especialidadId Int
  especialidad   Especialidad                   @relation(fields: [especialidadId], references: [id])
  tiposSub       TipoSubespecialidad[]
  kits           Kit[]
  hojasDeVida    HojaVidaInstrumento[]
  // ✅ NUEVO: solicitudes de instrumento del módulo Informes
  solicitudes    SolicitudRegistroInstrumento[] @relation("SolicitudSubespecialidad")
}

model TipoSubespecialidad {
  id                Int                   @id @default(autoincrement())
  codigo            String                @unique
  nombre            String
  estado            Boolean               @default(true)
  subespecialidadId Int
  subespecialidad   Subespecialidad       @relation(fields: [subespecialidadId], references: [id])
  hojasDeVida       HojaVidaInstrumento[]
}

model Marca {
  id          Int                   @id @default(autoincrement())
  codigo      String                @unique
  nombre      String                @unique
  estado      Boolean               @default(true)
  hojasDeVida HojaVidaInstrumento[]
}

// ==========================================
// CONFIGURACIÓN: INSUMOS Y PROVEEDORES
// ==========================================
model UnidadMedida {
  id      Int                @id @default(autoincrement())
  nombre  String             @unique
  estado  Boolean            @default(true)
  insumos InsumoQuirurgico[]
}

model Presentacion {
  id      Int                @id @default(autoincrement())
  nombre  String             @unique
  estado  Boolean            @default(true)
  insumos InsumoQuirurgico[]
}

model InsumoQuirurgico {
  id                     Int          @id @default(autoincrement())
  codigo                 String       @unique
  nombre                 String       @unique
  descripcion            String
  unidadMedidaId         Int
  unidadMedida           UnidadMedida @relation(fields: [unidadMedidaId], references: [id])
  presentacionId         Int
  presentacion           Presentacion @relation(fields: [presentacionId], references: [id])
  proveedorId            Int?
  proveedor              Proveedor?   @relation(fields: [proveedorId], references: [id])
  requiereEsterilizacion Boolean      @default(false)
  tipoEsterilizacion     String?
  estado                 Boolean      @default(true)
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  insumosUsados      InsumoCiclo[]
  // ✅ NUEVO: detalles de movimientos
  movimientosDetalle MovimientoInsumoDetalle[] @relation("InsumosMovimiento")
}

model Proveedor {
  id                    Int                   @id @default(autoincrement())
  codigo                String                @unique
  tipo                  String
  nombre                String
  nit                   String                @unique
  pais                  String
  ciudad                String
  estado                Boolean               @default(true)
  insumos               InsumoQuirurgico[]
  hojasDeVida           HojaVidaInstrumento[]
  reportesMantenimiento Reporte[]
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
}

// ==========================================
// CONFIGURACIÓN: SEDES Y QUIRÓFANOS
// ==========================================
model Sede {
  id          Int     @id @default(autoincrement())
  nombre      String  @unique
  pais        String  @default("Colombia")
  ciudad      String  @default("")
  direccion   String? @default("")
  responsable String? @default("")
  estado      Boolean @default(true)

  quirofanos        Quirofano[]
  kits              Kit[]
  instrumentos      HojaVidaInstrumento[]
  trasladosOrigen   HistorialTraslado[]   @relation("SedeOrigenTraslado")
  trasladosDestino  HistorialTraslado[]   @relation("SedeDestinoTraslado")
  ciclosDestino     CicloEsterilizacion[] @relation("SedeDestinoTraslado")
  // ✅ NUEVO: movimientos de insumos
  movimientosInsumo MovimientoInsumo[]    @relation("MovimientosInsumoSede")
}

model Quirofano {
  id     Int     @id @default(autoincrement())
  codigo String  @unique
  nombre String
  sedeId Int
  sede   Sede    @relation(fields: [sedeId], references: [id])
  estado Boolean @default(true)
}

// ==========================================
// MÓDULO: TM KIT
// ==========================================
model Kit {
  id                  Int             @id @default(autoincrement())
  codigoKit           String          @unique
  nombre              String
  numeroKit           Int
  cantidad            Int             @default(1)
  estado              String          @default("Habilitado")
  especialidadId      Int
  especialidad        Especialidad    @relation(fields: [especialidadId], references: [id])
  subespecialidadId   Int
  subespecialidad     Subespecialidad @relation(fields: [subespecialidadId], references: [id])
  tipoSubespecialidad String
  sedeId              Int?
  sede                Sede?           @relation(fields: [sedeId], references: [id])
  createdAt           DateTime        @default(now())

  instrumentos       InstrumentoEnKit[]
  hojasDeVida        HojaVidaInstrumento[]
  historialTraslados HistorialTraslado[]
  ciclos             CicloEsterilizacion[]
}

model InstrumentoEnKit {
  id            Int                 @id @default(autoincrement())
  kitId         Int
  kit           Kit                 @relation(fields: [kitId], references: [id])
  instrumentoId Int
  instrumento   HojaVidaInstrumento @relation(fields: [instrumentoId], references: [id])
}

// ==========================================
// MÓDULO: HOJA DE VIDA DE INSTRUMENTOS
// ==========================================
model HojaVidaInstrumento {
  id                      Int                 @id @default(autoincrement())
  codigo                  String              @unique
  especialidadId          Int
  especialidad            Especialidad        @relation(fields: [especialidadId], references: [id])
  subespecialidadId       Int
  subespecialidad         Subespecialidad     @relation(fields: [subespecialidadId], references: [id])
  tipoId                  Int
  tipo                    TipoSubespecialidad @relation(fields: [tipoId], references: [id])
  proveedorId             Int
  proveedor               Proveedor           @relation(fields: [proveedorId], references: [id])
  kitId                   Int?
  kit                     Kit?                @relation(fields: [kitId], references: [id])
  sedeId                  Int?
  sede                    Sede?               @relation(fields: [sedeId], references: [id])
  marcaId                 Int?
  marca                   Marca?              @relation(fields: [marcaId], references: [id])
  referencia              String?
  ciudad                  String?
  nombre                  String
  fabricante              String
  paisOrigen              String
  numeroSerie             String              @unique
  registroInvima          String              @unique
  material                String
  materialOtro            String?
  esterilizacion          String
  frecuenciaMantenimiento String
  proximoMantenimiento    DateTime?
  fechaMantenimientoRef   DateTime?
  observacionesTecnico    String?             @db.Text
  estadoActual            String              @default("P. registrar")
  cicloEsterilizacion     Int                 @default(0)
  propietarioId           Int
  propietario             Usuario             @relation("PropietarioInstrumento", fields: [propietarioId], references: [id])
  notasObservaciones      String?             @db.Text
  fechaCompra             DateTime?
  costo                   Float?
  iva                     Float?
  numeroFactura           String?
  vidaUtil                Float?
  fotoUrl                 String?
  garantiaUrl             String?
  registroInvimaUrl       String?
  codigoInstrumentoUrl    String?
  facturaUrl              String?
  estado                  String              @default("P. registrar")
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  historialTraslados HistorialTraslado[]
  kitsAsignados      InstrumentoEnKit[]
  reportesDano       Reporte[]
  escaneosCiclo      EscaneoInstrumento[]
  // ✅ NUEVO: link al módulo Informes - Instrumentos de 3ros
  ingresosTerceros   InstrumentoTercero[] @relation("InstrumentosTercerosLink")

  // Índices para queries frecuentes que filtran por estos campos.
  // FKs ya tienen índice automático.
  @@index([estado])
  @@index([updatedAt])
}

// ==========================================
// AUDITORÍA DE TRASLADOS DE INVENTARIO
// ==========================================
model HistorialTraslado {
  id              Int                  @id @default(autoincrement())
  instrumentoId   Int?
  instrumento     HojaVidaInstrumento? @relation(fields: [instrumentoId], references: [id])
  kitId           Int?
  kit             Kit?                 @relation(fields: [kitId], references: [id])
  sedeOrigenId    Int
  sedeOrigen      Sede                 @relation("SedeOrigenTraslado", fields: [sedeOrigenId], references: [id])
  sedeDestinoId   Int
  sedeDestino     Sede                 @relation("SedeDestinoTraslado", fields: [sedeDestinoId], references: [id])
  fechaTraslado   DateTime             @default(now())
  fechaDevolucion DateTime
  realizadoPor    String?              @default("Sistema")
}

// ==========================================
// MÓDULO: REPORTES DE DAÑOS / MANTENIMIENTO
// ==========================================
model Reporte {
  id                       Int                 @id @default(autoincrement())
  codigo                   String              @unique
  instrumentoId            Int
  instrumento              HojaVidaInstrumento @relation(fields: [instrumentoId], references: [id])
  tipoDano                 String
  descripcionDano          String?             @db.Text
  evidenciaFotoUrl         String?
  reportadoPorId           Int
  reportadoPor             Usuario             @relation("UsuarioReporta", fields: [reportadoPorId], references: [id])
  proveedorMantenimientoId Int?
  proveedorMantenimiento   Proveedor?          @relation(fields: [proveedorMantenimientoId], references: [id])
  descripcionMantenimiento String?             @db.Text
  informeMantenimientoUrl  String?
  destinoFinal             String?
  estado                   String              @default("Pendiente")
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt

  @@index([estado])
  @@index([createdAt])
}

// ==========================================
// TABLA PIVOTE: INSUMOS USADOS EN UN CICLO
// ==========================================
model InsumoCiclo {
  id       Int                 @id @default(autoincrement())
  cicloId  Int
  insumoId Int
  cantidad Int
  ciclo    CicloEsterilizacion @relation(fields: [cicloId], references: [id])
  insumo   InsumoQuirurgico    @relation(fields: [insumoId], references: [id])
}

// ==========================================
// MÓDULO: CICLO DE ESTERILIZACIÓN
// ==========================================
model CicloEsterilizacion {
  id                    Int                  @id @default(autoincrement())
  codigoCiclo           String               @unique
  kitId                 Int?
  kit                   Kit?                 @relation(fields: [kitId], references: [id])
  etapaActual           Int                  @default(0)
  responsableActualId   Int?
  responsable           Usuario?             @relation("ResponsableCiclo", fields: [responsableActualId], references: [id])
  tipoSellado           String?
  tipoEmpaque           String?
  cintaTest             Boolean              @default(false)
  quimicoInterno        Boolean              @default(false)
  lote                  String?
  observacionRotulado   String?              @db.Text
  tipoEsterilizacion    String?
  autoclaveTipo         String?
  valorIndicador        String?
  indicadorUrl          String?
  destinoSet            String?
  sedeDestinoId         Int?
  sedeDestino           Sede?                @relation("SedeDestinoTraslado", fields: [sedeDestinoId], references: [id])
  quirofanoDestino      String?
  instrumentadorDestino String?
  almacEstado           String?
  almacFechaIngreso     String?
  almacFechaVencimiento String?
  almacUbicacion        String?
  almacObservacion      String?              @db.Text
  evidenciaInsumosUrl   String?
  insumosUsados         InsumoCiclo[]
  estadoGlobal          String               @default("En Curso")
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  escaneos              EscaneoInstrumento[]

  @@index([estadoGlobal])
  @@index([createdAt])
  @@index([updatedAt])
}

model EscaneoInstrumento {
  id            Int                 @id @default(autoincrement())
  cicloId       Int
  ciclo         CicloEsterilizacion @relation(fields: [cicloId], references: [id])
  instrumentoId Int
  instrumento   HojaVidaInstrumento @relation(fields: [instrumentoId], references: [id])
  etapa         Int
  estadoFisico  String
  createdAt     DateTime            @default(now())
}

// ==========================================
// ✅ NUEVO: MOVIMIENTOS DE INSUMOS EN ALMACENAMIENTO
// ==========================================
model MovimientoInsumo {
  id            Int                       @id @default(autoincrement())
  tipo          String // 'Solicitud' | 'Consumo'
  fecha         DateTime
  responsableId Int
  responsable   Usuario                   @relation("MovimientosInsumo", fields: [responsableId], references: [id])
  sedeId        Int
  sede          Sede                      @relation("MovimientosInsumoSede", fields: [sedeId], references: [id])
  createdAt     DateTime                  @default(now())
  detalles      MovimientoInsumoDetalle[]

  @@index([fecha])
  @@index([tipo])
}

model MovimientoInsumoDetalle {
  id           Int              @id @default(autoincrement())
  movimientoId Int
  movimiento   MovimientoInsumo @relation(fields: [movimientoId], references: [id])
  insumoId     Int
  insumo       InsumoQuirurgico @relation("InsumosMovimiento", fields: [insumoId], references: [id])
  cantidad     Int
}

// ==========================================
// ✅ NUEVO: MÓDULO INFORMES — INSTRUMENTOS DE TERCEROS
// ==========================================

// Entidad externa (clínica, hospital, IPS) que envía instrumentos a procesar
model Entidad {
  id        Int      @id @default(autoincrement())
  codigo    String   @unique
  nombre    String   @unique
  nit       String?
  contacto  String?
  estado    Boolean  @default(true)
  createdAt DateTime @default(now())

  ingresos IngresoTercero[]
}

// Ingreso de instrumentos de un tercero a la central de esterilización
model IngresoTercero {
  id           Int      @id @default(autoincrement())
  idRecepcion  String   @unique
  fecha        DateTime
  hora         String
  entidadId    Int
  entidad      Entidad  @relation(fields: [entidadId], references: [id])
  evidenciaUrl String?
  estado       String   @default("Incompleto") // 'Incompleto' | 'Completo'
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  instrumentos InstrumentoTercero[]
  devoluciones DevolucionTercero[]

  @@index([fecha])
  @@index([estado])
}

// Línea de instrumento dentro de un ingreso (registrado o no registrado en HojaVida)
model InstrumentoTercero {
  id               Int                  @id @default(autoincrement())
  ingresoId        Int
  ingreso          IngresoTercero       @relation(fields: [ingresoId], references: [id], onDelete: Cascade)
  instrumentoId    Int?
  instrumento      HojaVidaInstrumento? @relation("InstrumentosTercerosLink", fields: [instrumentoId], references: [id])
  codigoExterno    String?
  nombreExterno    String?
  esRegistrado     Boolean              @default(true)
  cantidad         Int                  @default(1)
  cantidadDevuelta Int                  @default(0)

  detallesDevolucion DevolucionTerceroDetalle[]

  @@index([ingresoId])
}

// Devolución (parcial o total) de un ingreso de terceros
model DevolucionTercero {
  id            Int            @id @default(autoincrement())
  ingresoId     Int
  ingreso       IngresoTercero @relation(fields: [ingresoId], references: [id])
  fechaSalida   DateTime
  hora          String
  responsableId Int?
  responsable   Usuario?       @relation("DevolucionesResponsable", fields: [responsableId], references: [id])
  createdAt     DateTime       @default(now())

  detalles DevolucionTerceroDetalle[]

  @@index([fechaSalida])
}

// Detalle de instrumentos devueltos en una devolución
model DevolucionTerceroDetalle {
  id                   Int                @id @default(autoincrement())
  devolucionId         Int
  devolucion           DevolucionTercero  @relation(fields: [devolucionId], references: [id], onDelete: Cascade)
  instrumentoTerceroId Int
  instrumentoTercero   InstrumentoTercero @relation(fields: [instrumentoTerceroId], references: [id])
  cantidadDevuelta     Int
}

// Solicitud de registro de instrumento que no existe en HojaVida
model SolicitudRegistroInstrumento {
  id                Int             @id @default(autoincrement())
  codigo            String          @unique
  fotoUrl           String?
  nombre            String
  especialidadId    Int
  especialidad      Especialidad    @relation("SolicitudEspecialidad", fields: [especialidadId], references: [id])
  subespecialidadId Int
  subespecialidad   Subespecialidad @relation("SolicitudSubespecialidad", fields: [subespecialidadId], references: [id])
  solicitadoPorId   Int
  solicitadoPor     Usuario         @relation("SolicitudesUsuario", fields: [solicitadoPorId], references: [id])
  estado            String          @default("Pendiente") // Pendiente | Aprobado | Rechazado
  createdAt         DateTime        @default(now())

  @@index([estado])
}

// ==========================================
// ✅ NUEVO: MÓDULO INFORMES — INDICADOR DE PAQUETES E INSTRUMENTALES
// ==========================================
model IndicadorPaquete {
  id                 Int      @id @default(autoincrement())
  fecha              DateTime
  nombrePaciente     String
  intervencion       String
  quirofano          String
  equipo             String
  kit                String
  cantidad           Int      @default(1)
  indPaqueteUrl      String?
  indInstrumentalUrl String?
  createdAt          DateTime @default(now())

  @@index([fecha])
}

// ==========================================
// ✅ NUEVO: MÓDULO INFORMES — INDICADOR DE PRIMERA CARGA
// ==========================================
model IndicadorPrimeraCarga {
  id            Int      @id @default(autoincrement())
  fecha         DateTime
  lote          String
  equipo        String?
  instrumental  String?
  temperatura   String
  librasPresion String
  horaInicio    String
  horaSalida    String
  createdAt     DateTime @default(now())

  @@index([fecha])
}
